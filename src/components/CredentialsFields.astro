---
const { prefix = '' } = Astro.props;
---

<div class="form-grid-credentials">
    <div class="form-group">
        <label for={prefix + 'cerFile'}>Certificado (.cer)</label>
        <input type="file" id={prefix + 'cerFile'} accept=".cer" />
        <span id={prefix + 'cerInfo'} style="font-size: 0.8rem; color: #666; margin-top: 2px; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"></span>
    </div>
    <div class="form-group">
        <label for={prefix + 'keyFile'}>Llave Privada (.key)</label>
        <input type="file" id={prefix + 'keyFile'} accept=".key" />
        <span id={prefix + 'keyInfo'} style="font-size: 0.8rem; color: #666; margin-top: 2px; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"></span>
    </div>
    <div class="form-group full-width">
        <label for={prefix + 'password'}>Contraseña e.firma</label>
        <input type="password" id={prefix + 'password'} placeholder="Tu contraseña" />
    </div>
    <div class="form-group">
        <label for={prefix + 'rfc'}>RFC (Opcional si viene en el .cer)</label>
        <input type="text" id={prefix + 'rfc'} placeholder="ABCD123456..." />
    </div>
    <div class="form-group inline-row">
        <input type="checkbox" id={prefix + 'saveCreds'} checked />
        <label for={prefix + 'saveCreds'}>Guardar credenciales en este navegador</label>
    </div>
</div>

<style>
    .form-grid-credentials{
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        align-items: start;
        width: 100%;
        grid-column: 1 / -1;
    }

    .form-group{
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        min-width: 0;
    }
    .form-group.full-width{
        grid-column: 1 / -1;
    }

    .form-group label{
        display: block;
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--text-dim, #94a3b8);
        margin-bottom: 0;
    }

    .form-group input[type="file"],
    .form-group input[type="password"],
    .form-group input[type="text"] {
        background: rgba(15, 23, 42, 0.5);
        border: 1px solid var(--border, rgba(255, 255, 255, 0.1));
        border-radius: 0.75rem;
        padding: 0.75rem 1rem;
        color: white;
        font-family: inherit;
        transition: all 0.2s;
    }

    .form-group input[type="file"]::file-selector-button {
        background: var(--primary, #6366f1);
        color: white;
        border: none;
        border-radius: 0.5rem;
        padding: 0.4rem 0.8rem;
        margin-right: 0.75rem;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.2s;
    }

    .form-group input[type="file"]::file-selector-button:hover {
        background: var(--primary-hover, #4f46e5);
    }

    .form-group input:focus {
        outline: none;
        border-color: var(--primary, #6366f1);
        box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
    }

    .form-group input::placeholder {
        color: rgba(255, 255, 255, 0.4);
    }

    .form-group.inline-row{flex-direction:row; align-items:center; gap:0.5rem}
    .form-group.inline-row input[type="checkbox"]{flex:0 0 auto;}
    .form-group.inline-row label{margin:0; cursor:pointer; flex:1}

    @media (max-width: 640px){
        .form-grid-credentials{
            grid-template-columns: 1fr;
            gap: 1rem;
        }
    }
</style>
