---
import CredentialsFields from '../components/CredentialsFields.astro';
// src/pages/index.astro
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>CFDIsy | SAT Downloader</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #6366f1;
            --primary-hover: #4f46e5;
            --bg: #0f172a;
            --card-bg: rgba(30, 41, 59, 0.7);
            --text: #f8fafc;
            --text-dim: #94a3b8;
            --border: rgba(255, 255, 255, 0.1);
            --accent: #f43f5e;
            --success: #10b981;
        }

        /* Page internal push (toasts) */
        :global(.page-push-container) {
            position: fixed;
            top: 1rem;
            left: 0;
            right: 0;
            display: flex;
            justify-content: center;
            pointer-events: none;
            z-index: 1100;
        }

        :global(.page-push) {
            pointer-events: auto;
            min-width: 280px;
            max-width: 880px;
            margin: 0 1rem;
            background: #1e293b; /* slate-800 - better contrast */
            color: #f8fafc; /* slate-50 - light text */
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 0.75rem 1rem;
            border-radius: 0.75rem;
            box-shadow: 0 8px 20px rgba(2,6,23,0.25);
            display: flex;
            gap: 0.75rem;
            align-items: center;
            transform: translateY(-6px);
            opacity: 0;
            transition: transform 0.25s, opacity 0.25s;
        }

        :global(.page-push.show) {
            transform: translateY(0);
            opacity: 1;
        }

        :global(.page-push .push-title) { font-weight: 700; }
        :global(.page-push .push-body) { color: inherit; font-size: 0.95rem; opacity: 0.95; }
        :global(.page-push .push-close) { margin-left: 8px; opacity: 0.95; cursor: pointer; font-weight: 700; }

        /* Backgrounds per type (solid, high contrast) - higher specificity */
        :global(.page-push.info) { 
            background: #fef3c7 !important; 
            color: #78350f !important; 
            border-left: 4px solid #f59e0b; 
        }
        :global(.page-push.success) { 
            background: #065f46 !important; 
            color: #ecfdf5 !important; 
            border-left: 4px solid #10b981; 
        }
        :global(.page-push.error) { 
            background: #7f1d1d !important; 
            color: #fef2f2 !important; 
            border-left: 4px solid #f43f5e; 
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg);
            background-image: 
                radial-gradient(at 0% 0%, rgba(99, 102, 241, 0.15) 0, transparent 50%), 
                radial-gradient(at 100% 100%, rgba(244, 63, 94, 0.1) 0, transparent 50%);
            color: var(--text);
            margin: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .container {
            width: 90%;
            max-width: 800px;
            margin: 2rem auto;
            padding: 2rem;
        }

        header {
            text-align: center;
            margin-bottom: 3rem;
        }

        h1 {
            font-size: 3rem;
            margin: 0;
            background: linear-gradient(to right, #818cf8, #f472b6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 700;
        }

        p.subtitle {
            color: var(--text-dim);
            font-size: 1.1rem;
        }

        .card {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--border);
            border-radius: 1.5rem;
            padding: 2rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .full-width {
            grid-column: 1 / -1;
        }

        label {
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--text-dim);
        }

        .hint {
            font-size: 0.7rem;
            opacity: 0.6;
            margin-left: 4px;
            font-weight: 400;
        }

        input, select {
            background: rgba(15, 23, 42, 0.5);
            border: 1px solid var(--border);
            border-radius: 0.75rem;
            padding: 0.75rem 1rem;
            color: white;
            font-family: inherit;
            transition: all 0.2s;
        }

        #savedRfc,
        #presetYear,
        #presetMonth,
        #type {
            background: rgba(15, 23, 42, 0.5);
            border: 1px solid var(--border);
            border-radius: 0.75rem;
            padding: 0.75rem 1rem;
            color: white;
            font-family: inherit;
            transition: all 0.2s;
            width: 100%;
        }

        #savedRfc option,
        #presetYear option,
        #presetMonth option,
        #type option {
            background: rgba(15, 23, 42, 0.95);
            color: white;
            border: none;
            padding: 0.5rem;
        }

        #savedRfc:focus,
        #presetYear:focus,
        #presetMonth:focus,
        #type:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
        }

        /* Mejorar visibilidad del icono calendario en inputs date */
        input[type="date"] {
            color: var(--text);
            background: rgba(15, 23, 42, 0.5);
            padding-right: 1.8rem; /* dejar más espacio para el icono agrandado */
        }

        input[type="date"]::-webkit-datetime-edit { color: var(--text); }
        input[type="date"]::-webkit-calendar-picker-indicator {
            filter: invert(1) brightness(1.2) contrast(1.2);
            opacity: 0.98;
            cursor: pointer;
            transform: scale(1.45);
            width: 1.3em;
            height: 1.3em;
            vertical-align: middle;
        }
        /* IE/Edge fallback visibility tweaks */
        input[type="date"]::-ms-clear, input[type="date"]::-ms-expand {
            display: block;
            color: var(--text);
            transform: scale(1.2);
        }

        input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
        }

        .btn {
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 0.75rem;
            padding: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            margin-top: 1rem;
        }

        .btn:hover {
            background: var(--primary-hover);
            transform: translateY(-1px);
        }

        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .table-responsive {
            overflow-x: auto;
            margin-top: 1rem;
        }

        .xml-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
            color: white;
        }

        .xml-table th {
            text-align: left;
            padding: 1rem;
            background: rgba(255, 255, 255, 0.05);
            font-weight: 600;
            color: var(--text-dim);
            border-bottom: 2px solid var(--border);
        }

        .xml-table td {
            padding: 1rem;
            border-bottom: 1px solid var(--border);
        }

        .xml-table tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }

        .xml-table .uuid {
            font-family: monospace;
            font-size: 0.75rem;
            color: var(--primary);
        }

        .btn-delete-small {
            background: rgba(244, 63, 94, 0.1);
            color: #fb7185;
            border: 1px solid rgba(244, 63, 94, 0.2);
            padding: 0.25rem 0.5rem;
            border-radius: 0.25rem;
            cursor: pointer;
            font-size: 0.7rem;
            transition: all 0.2s;
        }

        .btn-delete-small:hover {
            background: rgba(244, 63, 94, 0.2);
            border-color: #fb7185;
        }

        .download-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .download-item {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: 1rem;
            padding: 1rem;
            margin-bottom: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .item-info h3 {
            margin: 0;
            font-size: 1rem;
        }

        .item-info p {
            margin: 0;
            font-size: 0.8rem;
            color: var(--text-dim);
        }

        .badge {
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .badge.pending { background: rgba(234, 179, 8, 0.2); color: #fbbf24; }
        .badge.ready { background: rgba(16, 185, 129, 0.2); color: #34d399; }
        .badge.error { background: rgba(244, 63, 94, 0.2); color: #fb7185; }

        .text-pending { color: #fbbf24; }
        .text-ready { color: #34d399; }
        .text-downloaded { color: var(--primary); }
        .text-error { color: #fb7185; }

        .loader {
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s ease-in-out infinite;
        }

        /* Modal Styles */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(8px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .modal-overlay.active {
            display: flex;
            opacity: 1;
        }

        .modal {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 1.5rem;
            padding: 2.5rem;
            max-width: 450px;
            width: 90%;
            text-align: center;
            transform: scale(0.9);
            transition: transform 0.3s;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .modal-overlay.active .modal {
            transform: scale(1);
        }

        .modal-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .modal-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 0.75rem;
        }

        .modal-message {
            color: var(--text-dim);
            line-height: 1.6;
            margin-bottom: 2rem;
        }

        .modal-btn {
            background: var(--primary);
            color: white;
            border: none;
            padding: 0.75rem 2rem;
            border-radius: 0.75rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
        }

        .modal-btn:hover {
            background: var(--primary-hover);
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Mobile tweaks */
        @media (max-width: 640px) {
            .container {
                width: 96%;
                padding: 1rem;
                margin: 1rem auto;
            }

            .card {
                padding: 1rem;
                border-radius: 1rem;
            }

            .form-grid {
                grid-template-columns: 1fr;
                gap: 1rem;
            }

            .form-group.full-width {
                flex-direction: column;
            }

            header h1 { font-size: 2rem; }

            .xml-table th, .xml-table td { padding: 0.6rem; font-size: 0.8rem; }

            .download-item { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
        }
    </style>
</head>
<body>
    <div id="pagePushContainer" class="page-push-container"></div>
    <div class="container">
        <header>
            <h1>CFDIsy Downloader</h1>
            <p class="subtitle">Descarga masiva de facturas desde el Web Service del SAT de forma segura.</p>
        </header>

        <div class="card">
            <form id="downloadForm">
                <div class="form-grid">
                    <div class="form-group full-width" style="display: none;">
                        <label for="savedRfc">RFCs Guardados</label>
                        <select id="savedRfc">
                            <option value="">-- Seleccionar RFC Guardado --</option>
                        </select>
                    </div>
                    <CredentialsFields prefix="" />
                    <div class="form-group full-width" style="border-top: 1px solid var(--border); padding-top: 1rem;">
                        <label>Relleno rápido por período</label>
                        <div style="display: flex; gap: 0.5rem;">
                            <select id="presetYear">
                                <option value="">Año</option>
                            </select>
                            <select id="presetMonth">
                                <option value="">Mes</option>
                                <option value="0">Enero</option>
                                <option value="1">Febrero</option>
                                <option value="2">Marzo</option>
                                <option value="3">Abril</option>
                                <option value="4">Mayo</option>
                                <option value="5">Junio</option>
                                <option value="6">Julio</option>
                                <option value="7">Agosto</option>
                                <option value="8">Septiembre</option>
                                <option value="9">Octubre</option>
                                <option value="10">Noviembre</option>
                                <option value="11">Diciembre</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="dateStart">Fecha Inicial <span class="hint">(dd/mm/aaaa)</span></label>
                        <input type="date" id="dateStart" required />
                    </div>
                    <div class="form-group">
                        <label for="dateEnd">Fecha Final <span class="hint">(dd/mm/aaaa)</span></label>
                        <input type="date" id="dateEnd" required />
                    </div>
                    <div class="form-group">
                        <label for="type">Tipo de CFDI</label>
                        <select id="type">
                            <option value="emitidas">Emitidas</option>
                            <option value="recibidas">Recibidas</option>
                        </select>
                    </div>
                    <!-- RFC and save checkbox are included inside CredentialsFields -->
                    
                    <button type="submit" class="btn full-width" id="submitBtn">
                        <span>Iniciar Solicitud de Descarga</span>
                    </button>
                </div>
            </form>
        </div>

        <div class="status-container" id="statusContainer">
            <h2>Solicitudes en Curso</h2>
            <div class="table-responsive">
                <table class="requests-table" id="requestsTable" style="width:100%;">
                    <thead>
                        <tr>
                            <th style="width:14%;">RFC</th>
                            <th style="width:12%;">Solicitud</th>
                            <th style="width:24%;">Rango</th>
                            <th style="width:10%;">Tipo</th>
                            <th style="width:18%;">Estado</th>
                            <th style="width:22%;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="downloadList">
                        <!-- Solicitudes se añadirán aquí como filas -->
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card" id="historyCard" style="margin-top: 2.5rem; display: none;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h2>Facturas Descargadas</h2>
                <div style="display: flex; gap: 0.5rem;">
                    <button id="exportExcelEmitidos" class="btn" style="background: var(--success); margin: 0; padding: 0.5rem 1rem; font-size: 0.8rem;">
                        <span>Exportar Excel (Emitidos)</span>
                    </button>
                    <button id="exportExcelRecibidos" class="btn" style="background: var(--success); margin: 0; padding: 0.5rem 1rem; font-size: 0.8rem;">
                        <span>Exportar Excel (Recibidos)</span>
                    </button>
                    <button id="deleteAllXmls" class="btn" style="background: var(--accent); margin: 0; padding: 0.5rem 1rem; font-size: 0.8rem;">
                        <span>Borrar Todo</span>
                    </button>
                </div>
            </div>
            
            <div class="table-responsive">
                <table class="xml-table" id="xmlTable">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>RFC Emisor</th>
                            <th>RFC Receptor</th>
                            <th>UUID</th>
                            <th>Total</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="xmlTableBody">
                        <!-- XMLs guardados aquí -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal Template -->
    <div class="modal-overlay" id="modalOverlay">
        <div class="modal">
            <div class="modal-icon" id="modalIcon">🔔</div>
            <div class="modal-title" id="modalTitle">Atención</div>
            <div class="modal-message" id="modalMessage">Mensaje informativo.</div>
            <div style="display:flex; gap:0.5rem; justify-content:center; margin-top:1rem;">
                <button class="modal-btn" id="modalConfirm" style="display:none; background: var(--success);">Confirmar</button>
                <button class="modal-btn" id="modalCancel" style="display:none; background: rgba(244, 63, 94, 0.06); color: var(--accent);">Cancelar</button>
                <button class="modal-btn" id="modalClose">Entendido</button>
            </div>
        </div>
    </div>

    <!-- Credenciales Modal Template -->
    <div class="modal-overlay" id="credsModalOverlay" style="display:none;">
        <div class="modal">
            <div class="modal-icon">🔒</div>
            <div class="modal-title">Ingresar Credenciales</div>
            <div class="modal-message" id="credsModalMessage">
                <CredentialsFields prefix="modal-" />
            </div>
            <div style="display:flex; gap:0.5rem; justify-content:center; margin-top:1rem;">
                <button class="modal-btn" id="credsModalConfirm">Usar Credenciales</button>
                <button class="modal-btn" id="credsModalCancel" style="background: rgba(244, 63, 94, 0.06); color: var(--accent);">Cancelar</button>
            </div>
        </div>
    </div>

    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/fast-xml-parser/4.3.6/fxparser.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    
    <script is:inline>
        const parser = new XMLParser({
            ignoreAttributes: false,
            attributeNamePrefix: '',
            removeNSPrefix: true
        });

        const form = document.getElementById('downloadForm');
        const submitBtn = document.getElementById('submitBtn');
        const statusContainer = document.getElementById('statusContainer');
        const downloadList = document.getElementById('downloadList');
        const dateStartInput = document.getElementById('dateStart');
        const dateEndInput = document.getElementById('dateEnd');
        const cerInput = document.getElementById('cerFile');
        const keyInput = document.getElementById('keyFile');
        const passwordInput = document.getElementById('password');
        const rfcInput = document.getElementById('rfc');
        const typeInput = document.getElementById('type');
        const saveCredsCheckbox = document.getElementById('saveCreds');
        const savedRfcSelect = document.getElementById('savedRfc');
        const presetYear = document.getElementById('presetYear');
        const presetMonth = document.getElementById('presetMonth');

        const historyCard = document.getElementById('historyCard');
        const xmlTableBody = document.getElementById('xmlTableBody');
        const exportExcelEmitidos = document.getElementById('exportExcelEmitidos');
        const exportExcelRecibidos = document.getElementById('exportExcelRecibidos');
        const deleteAllXmls = document.getElementById('deleteAllXmls');

        let savedXmls = JSON.parse(localStorage.getItem('satXmlHistory') || '[]');

        // Llenar años en el select
        const currentYear = new Date().getFullYear();
        for (let y = currentYear; y >= currentYear - 5; y--) {
            const opt = document.createElement('option');
            opt.value = y.toString();
            opt.textContent = y.toString();
            presetYear.appendChild(opt);
        }

        function updateDatesFromPreset() {
            const year = presetYear.value;
            const month = presetMonth.value;
            if (year && month) {
                const y = parseInt(year);
                const m = parseInt(month);
                const firstDay = new Date(y, m, 1);
                const lastDay = new Date(y, m + 1, 0);
                
                const formatDate = (date) => {
                    const d = date.getDate().toString().padStart(2, '0');
                    const mo = (date.getMonth() + 1).toString().padStart(2, '0');
                    const ye = date.getFullYear();
                    return `${ye}-${mo}-${d}`;
                };
                
                dateStartInput.value = formatDate(firstDay);
                dateEndInput.value = formatDate(lastDay);
                
                localStorage.setItem('satDateStart', dateStartInput.value);
                localStorage.setItem('satDateEnd', dateEndInput.value);
            }
        }

        presetYear.addEventListener('change', updateDatesFromPreset);
        presetMonth.addEventListener('change', updateDatesFromPreset);

        const modalOverlay = document.getElementById('modalOverlay');
        const modalIcon = document.getElementById('modalIcon');
        const modalTitle = document.getElementById('modalTitle');
        const modalMessage = document.getElementById('modalMessage');
        const modalClose = document.getElementById('modalClose');
        const modalConfirm = document.getElementById('modalConfirm');
        const modalCancel = document.getElementById('modalCancel');

        function showModal(title, message, type = 'info') {
            modalTitle.textContent = title;
            modalMessage.textContent = message;
            
            if (type === 'success') modalIcon.textContent = '✅';
            else if (type === 'error') modalIcon.textContent = '❌';
            else modalIcon.textContent = '🔔';
            
            modalClose.style.display = 'inline-block';
            if (modalConfirm) modalConfirm.style.display = 'none';
            if (modalCancel) modalCancel.style.display = 'none';
            modalOverlay.classList.add('active');
        }

        modalClose.addEventListener('click', () => {
            modalOverlay.classList.remove('active');
        });

        function showConfirm(title, message) {
            return new Promise((resolve) => {
                modalTitle.textContent = title;
                modalMessage.textContent = message;
                modalIcon.textContent = '❗';

                modalClose.style.display = 'none';
                if (modalConfirm) modalConfirm.style.display = 'inline-block';
                if (modalCancel) modalCancel.style.display = 'inline-block';

                const cleanup = () => {
                    modalOverlay.classList.remove('active');
                    if (modalConfirm) modalConfirm.onclick = null;
                    if (modalCancel) modalCancel.onclick = null;
                };

                if (modalConfirm) modalConfirm.onclick = () => { cleanup(); resolve(true); };
                if (modalCancel) modalCancel.onclick = () => { cleanup(); resolve(false); };

                modalOverlay.classList.add('active');
            });
        }

        function showToast(title, message, type = 'info', timeout = 5000) {
            const container = document.getElementById('pagePushContainer');
            if (!container) { showModal(title, message, type); return; }

            const push = document.createElement('div');
            push.className = `page-push ${type}`;
            push.setAttribute('role', 'status');
            push.setAttribute('aria-live', 'polite');
            push.innerHTML = `<div style="flex:1"><div class="push-title">${title}</div><div class="push-body">${message}</div></div><div class="push-close" aria-label="Cerrar">✕</div>`;

            const closeBtn = push.querySelector('.push-close');
            if (closeBtn) closeBtn.addEventListener('click', () => {
                push.classList.remove('show');
                setTimeout(() => push.remove(), 300);
            });

            container.appendChild(push);
            requestAnimationFrame(() => push.classList.add('show'));

            const hide = () => {
                push.classList.remove('show');
                setTimeout(() => { try { push.remove(); } catch {} }, 300);
            };

            const t = setTimeout(hide, timeout);
            push.addEventListener('mouseenter', () => clearTimeout(t));
            push.addEventListener('mouseleave', () => setTimeout(hide, 2000));
        }

        function maybeNotify(title, message, type = 'info') {
            if (type === 'error') {
                showModal(title, message, type);
            } else {
                showToast(title, message, type);
            }
        }

        // Estructura de credenciales guardadas
        let savedCredentials = JSON.parse(localStorage.getItem('satCredentials') || '{}');
        let selectedSavedCreds = null;

        function updateSavedRfcDropdown() {
            const rfcs = Object.keys(savedCredentials);
            if (rfcs.length > 0) {
                savedRfcSelect.parentElement.style.display = 'flex';
                savedRfcSelect.innerHTML = '<option value="">-- Seleccionar RFC Guardado --</option>' + 
