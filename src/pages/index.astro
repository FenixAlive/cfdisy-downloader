---
// src/pages/index.astro
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>CFDIsy | SAT Downloader</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #6366f1;
            --primary-hover: #4f46e5;
            --bg: #0f172a;
            --card-bg: rgba(30, 41, 59, 0.7);
            --text: #f8fafc;
            --text-dim: #94a3b8;
            --border: rgba(255, 255, 255, 0.1);
            --accent: #f43f5e;
            --success: #10b981;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg);
            background-image: 
                radial-gradient(at 0% 0%, rgba(99, 102, 241, 0.15) 0, transparent 50%), 
                radial-gradient(at 100% 100%, rgba(244, 63, 94, 0.1) 0, transparent 50%);
            color: var(--text);
            margin: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .container {
            width: 90%;
            max-width: 800px;
            margin: 2rem auto;
            padding: 2rem;
        }

        header {
            text-align: center;
            margin-bottom: 3rem;
        }

        h1 {
            font-size: 3rem;
            margin: 0;
            background: linear-gradient(to right, #818cf8, #f472b6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 700;
        }

        p.subtitle {
            color: var(--text-dim);
            font-size: 1.1rem;
        }

        .card {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--border);
            border-radius: 1.5rem;
            padding: 2rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .full-width {
            grid-column: 1 / -1;
        }

        label {
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--text-dim);
        }

        .hint {
            font-size: 0.7rem;
            opacity: 0.6;
            margin-left: 4px;
            font-weight: 400;
        }

        input, select {
            background: rgba(15, 23, 42, 0.5);
            border: 1px solid var(--border);
            border-radius: 0.75rem;
            padding: 0.75rem 1rem;
            color: white;
            font-family: inherit;
            transition: all 0.2s;
        }

        input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
        }

        .btn {
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 0.75rem;
            padding: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            margin-top: 1rem;
        }

        .btn:hover {
            background: var(--primary-hover);
            transform: translateY(-1px);
        }

        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .status-container {
            margin-top: 2rem;
            display: none;
        }

        .download-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .download-item {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: 1rem;
            padding: 1rem;
            margin-bottom: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .item-info h3 {
            margin: 0;
            font-size: 1rem;
        }

        .item-info p {
            margin: 0;
            font-size: 0.8rem;
            color: var(--text-dim);
        }

        .badge {
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .badge.pending { background: rgba(234, 179, 8, 0.2); color: #fbbf24; }
        .badge.ready { background: rgba(16, 185, 129, 0.2); color: #34d399; }
        .badge.error { background: rgba(244, 63, 94, 0.2); color: #fb7185; }

        .text-pending { color: #fbbf24; }
        .text-ready { color: #34d399; }
        .text-downloaded { color: var(--primary); }
        .text-error { color: #fb7185; }

        .loader {
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s ease-in-out infinite;
        }

        /* Modal Styles */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(8px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .modal-overlay.active {
            display: flex;
            opacity: 1;
        }

        .modal {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 1.5rem;
            padding: 2.5rem;
            max-width: 450px;
            width: 90%;
            text-align: center;
            transform: scale(0.9);
            transition: transform 0.3s;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .modal-overlay.active .modal {
            transform: scale(1);
        }

        .modal-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .modal-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 0.75rem;
        }

        .modal-message {
            color: var(--text-dim);
            line-height: 1.6;
            margin-bottom: 2rem;
        }

        .modal-btn {
            background: var(--primary);
            color: white;
            border: none;
            padding: 0.75rem 2rem;
            border-radius: 0.75rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
        }

        .modal-btn:hover {
            background: var(--primary-hover);
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>CFDIsy Downloader</h1>
            <p class="subtitle">Descarga masiva de facturas desde el Web Service del SAT de forma segura.</p>
        </header>

        <div class="card">
            <form id="downloadForm">
                <div class="form-grid">
                    <div class="form-group full-width" style="display: none;">
                        <label for="savedRfc">RFCs Guardados</label>
                        <select id="savedRfc">
                            <option value="">-- Seleccionar RFC Guardado --</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="cerFile">Certificado (.cer)</label>
                        <input type="file" id="cerFile" accept=".cer" required />
                        <span id="cerInfo" style="font-size: 0.8rem; color: #666; margin-top: 2px; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"></span>
                    </div>
                    <div class="form-group">
                        <label for="keyFile">Llave Privada (.key)</label>
                        <input type="file" id="keyFile" accept=".key" required />
                        <span id="keyInfo" style="font-size: 0.8rem; color: #666; margin-top: 2px; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"></span>
                    </div>
                    <div class="form-group full-width">
                        <label for="password">Contraseña e.firma</label>
                        <input type="password" id="password" placeholder="Tu contraseña" required />
                    </div>
                    <div class="form-group full-width" style="border-top: 1px solid var(--border); padding-top: 1rem;">
                        <label>Relleno rápido por período</label>
                        <div style="display: flex; gap: 0.5rem;">
                            <select id="presetYear">
                                <option value="">Año</option>
                            </select>
                            <select id="presetMonth">
                                <option value="">Mes</option>
                                <option value="0">Enero</option>
                                <option value="1">Febrero</option>
                                <option value="2">Marzo</option>
                                <option value="3">Abril</option>
                                <option value="4">Mayo</option>
                                <option value="5">Junio</option>
                                <option value="6">Julio</option>
                                <option value="7">Agosto</option>
                                <option value="8">Septiembre</option>
                                <option value="9">Octubre</option>
                                <option value="10">Noviembre</option>
                                <option value="11">Diciembre</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="dateStart">Fecha Inicial <span class="hint">(dd/mm/aaaa)</span></label>
                        <input type="date" id="dateStart" required />
                    </div>
                    <div class="form-group">
                        <label for="dateEnd">Fecha Final <span class="hint">(dd/mm/aaaa)</span></label>
                        <input type="date" id="dateEnd" required />
                    </div>
                    <div class="form-group">
                        <label for="type">Tipo de CFDI</label>
                        <select id="type">
                            <option value="emitidas">Emitidas</option>
                            <option value="recibidas">Recibidas</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="rfc">RFC (Opcional si viene en el .cer)</label>
                        <input type="text" id="rfc" placeholder="ABCD123456..."/>
                    </div>
                    
                    <div class="form-group full-width" style="flex-direction: row; align-items: center; gap: 0.5rem; margin-top: 0.5rem;">
                        <input type="checkbox" id="saveCreds" style="width: auto;" />
                        <label for="saveCreds" style="margin: 0; cursor: pointer;">Guardar credenciales en este navegador</label>
                    </div>
                    
                    <button type="submit" class="btn full-width" id="submitBtn">
                        <span>Iniciar Solicitud de Descarga</span>
                    </button>
                </div>
            </form>
        </div>

        <div class="status-container" id="statusContainer">
            <h2>Solicitudes en Curso</h2>
            <ul class="download-list" id="downloadList">
                <!-- Solicitudes se añadirán aquí -->
            </ul>
        </div>
    </div>

    <!-- Modal Template -->
    <div class="modal-overlay" id="modalOverlay">
        <div class="modal">
            <div class="modal-icon" id="modalIcon">🔔</div>
            <div class="modal-title" id="modalTitle">Atención</div>
            <div class="modal-message" id="modalMessage">Mensaje informativo.</div>
            <button class="modal-btn" id="modalClose">Entendido</button>
        </div>
    </div>

    <script>
        import JSZip from 'jszip';

        const form = document.getElementById('downloadForm') as HTMLFormElement;
        const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
        const statusContainer = document.getElementById('statusContainer') as HTMLElement;
        const downloadList = document.getElementById('downloadList') as HTMLElement;
        const dateStartInput = document.getElementById('dateStart') as HTMLInputElement;
        const dateEndInput = document.getElementById('dateEnd') as HTMLInputElement;
        const cerInput = document.getElementById('cerFile') as HTMLInputElement;
        const keyInput = document.getElementById('keyFile') as HTMLInputElement;
        const passwordInput = document.getElementById('password') as HTMLInputElement;
        const rfcInput = document.getElementById('rfc') as HTMLInputElement;
        const typeInput = document.getElementById('type') as HTMLSelectElement;
        const saveCredsCheckbox = document.getElementById('saveCreds') as HTMLInputElement;
        const savedRfcSelect = document.getElementById('savedRfc') as HTMLSelectElement;
        const presetYear = document.getElementById('presetYear') as HTMLSelectElement;
        const presetMonth = document.getElementById('presetMonth') as HTMLSelectElement;

        // Llenar años en el select
        const currentYear = new Date().getFullYear();
        for (let y = currentYear; y >= currentYear - 5; y--) {
            const opt = document.createElement('option');
            opt.value = y.toString();
            opt.textContent = y.toString();
            presetYear.appendChild(opt);
        }

        function updateDatesFromPreset() {
            const year = presetYear.value;
            const month = presetMonth.value;
            if (year && month) {
                const y = parseInt(year);
                const m = parseInt(month);
                const firstDay = new Date(y, m, 1);
                const lastDay = new Date(y, m + 1, 0);
                
                // Formato ISO para el input date: YYYY-MM-DD
                const formatDate = (date: Date) => {
                    const d = date.getDate().toString().padStart(2, '0');
                    const mo = (date.getMonth() + 1).toString().padStart(2, '0');
                    const ye = date.getFullYear();
                    return `${ye}-${mo}-${d}`;
                };
                
                (dateStartInput as HTMLInputElement).value = formatDate(firstDay);
                (dateEndInput as HTMLInputElement).value = formatDate(lastDay);
                
                // Guardar en localStorage
                localStorage.setItem('satDateStart', (dateStartInput as HTMLInputElement).value);
                localStorage.setItem('satDateEnd', (dateEndInput as HTMLInputElement).value);
            }
        }

        presetYear.addEventListener('change', updateDatesFromPreset);
        presetMonth.addEventListener('change', updateDatesFromPreset);

        const modalOverlay = document.getElementById('modalOverlay') as HTMLElement;
        const modalIcon = document.getElementById('modalIcon') as HTMLElement;
        const modalTitle = document.getElementById('modalTitle') as HTMLElement;
        const modalMessage = document.getElementById('modalMessage') as HTMLElement;
        const modalClose = document.getElementById('modalClose') as HTMLButtonElement;

        function showModal(title: string, message: string, type: 'info' | 'success' | 'error' = 'info') {
            modalTitle.textContent = title;
            modalMessage.textContent = message;
            
            if (type === 'success') modalIcon.textContent = '✅';
            else if (type === 'error') modalIcon.textContent = '❌';
            else modalIcon.textContent = '🔔';
            
            modalOverlay.classList.add('active');
        }

        modalClose.addEventListener('click', () => {
            modalOverlay.classList.remove('active');
        });

        // Estructura de credenciales guardadas...
        let savedCredentials = JSON.parse(localStorage.getItem('satCredentials') || '{}');
        let selectedSavedCreds: any = null;

        function updateSavedRfcDropdown() {
            const rfcs = Object.keys(savedCredentials);
            if (rfcs.length > 0) {
                savedRfcSelect.parentElement!.style.display = 'flex';
                savedRfcSelect.innerHTML = '<option value="">-- Seleccionar RFC Guardado --</option>' + 
                    rfcs.map(rfc => `<option value="${rfc}">${rfc}</option>`).join('');
            } else {
                savedRfcSelect.parentElement!.style.display = 'none';
            }
        }

        updateSavedRfcDropdown();

        savedRfcSelect.addEventListener('change', () => {
            const rfc = savedRfcSelect.value;
            const cerInfo = document.getElementById('cerInfo');
            const keyInfo = document.getElementById('keyInfo');
            
            if (rfc) {
                const creds = savedCredentials[rfc];
                if (!creds || !creds.cerBase64 || !creds.keyBase64) {
                    showModal('Credenciales Incompletas', `Faltan archivos .cer o .key para el RFC ${rfc}. Por favor, vuelve a cargarlos.`, 'error');
                    savedRfcSelect.value = "";
                    selectedSavedCreds = null;
                    cerInput.required = true;
                    keyInput.required = true;
                    if (cerInfo) cerInfo.textContent = '';
                    if (keyInfo) keyInfo.textContent = '';
                    return;
                }
                
                rfcInput.value = rfc;
                passwordInput.value = creds.password;
                selectedSavedCreds = creds;
                
                // Quitar requerimiento de archivos ya que usamos los guardados
                cerInput.required = false;
                keyInput.required = false;
                
                // Mostrar feedback visual
                if (cerInfo) cerInfo.textContent = `📁 Guardado: ${creds.cerName}`;
                if (keyInfo) keyInfo.textContent = `📁 Guardado: ${creds.keyName}`;
                
                console.log(`Cargadas credenciales para ${rfc}. (Archivos: ${creds.cerName}, ${creds.keyName})`);
            } else {
                selectedSavedCreds = null;
                cerInput.required = true;
                keyInput.required = true;
                if (cerInfo) cerInfo.textContent = '';
                if (keyInfo) keyInfo.textContent = '';
            }
        });

        // Cargar solicitudes previas de localStorage
        let activeRequests = JSON.parse(localStorage.getItem('satRequests') || '[]');
        
        // Cargar fechas previas
        const savedStart = localStorage.getItem('satDateStart');
        const savedEnd = localStorage.getItem('satDateEnd');
        if (savedStart && dateStartInput) (dateStartInput as HTMLInputElement).value = savedStart;
        if (savedEnd && dateEndInput) (dateEndInput as HTMLInputElement).value = savedEnd;

        // Guardar fechas al cambiar
        dateStartInput.addEventListener('change', () => localStorage.setItem('satDateStart', (dateStartInput as HTMLInputElement).value));
        dateEndInput.addEventListener('change', () => localStorage.setItem('satDateEnd', (dateEndInput as HTMLInputElement).value));

        function updateUI() {
            if (!statusContainer || !downloadList) return;
            if (activeRequests.length > 0) {
                statusContainer.style.display = 'block';
                downloadList.innerHTML = activeRequests.map((req: any, index: number) => {
                    let statusLabel = 'Pendiente';
                    if (req.status === 'ready') statusLabel = '¡Listo para descargar!';
                    if (req.status === 'downloaded') statusLabel = `Descargado (${req.xmlCount} XMLs)`;
                    if (req.status === 'error') statusLabel = 'Error';

                    return `
                        <li class="download-item">
                            <div class="item-info">
                                <h3 style="color: var(--primary); margin-bottom: 2px;">RFC: ${req.rfc || 'N/A'}</h3>
                                <p style="font-size: 0.75rem; opacity: 0.7; margin-bottom: 4px;">Solicitud: ${req.id}</p>
                                <p>${req.dateStart} al ${req.dateEnd} | ${req.type}</p>
                                <p style="margin-top: 4px; font-weight: 600;" class="text-${req.status}">${statusLabel}</p>
                            </div>
                            <div class="item-actions" style="display: flex; gap: 0.5rem; align-items: center;">
                                ${req.status === 'ready' || req.status === 'downloaded' ? `
                                    <button class="btn-download" data-id="${req.id}" style="background: ${req.status === 'downloaded' ? 'var(--primary)' : 'var(--success)'}; color: white; border: none; padding: 0.5rem 1rem; border-radius: 0.5rem; cursor: pointer; font-weight: 600; font-size: 0.8rem;">
                                        ${req.status === 'downloaded' ? 'Re-descargar ZIP' : 'Descargar ZIP'}
                                    </button>
                                ` : ''}
                                ${req.status === 'downloaded' || req.status === 'error' ? `
                                    <button class="btn-delete" data-index="${index}" style="background: rgba(244, 63, 94, 0.1); color: var(--accent); border: 1px solid var(--accent); padding: 0.5rem; border-radius: 0.5rem; cursor: pointer; font-size: 0.7rem;">
                                        Eliminar
                                    </button>
                                ` : ''}
                                ${req.status === 'pending' ? '<div class="loader"></div>' : ''}
                            </div>
                        </li>
                    `;
                }).join('');

                // Agregar listeners a los nuevos botones
                document.querySelectorAll('.btn-download').forEach(btn => {
                    btn.addEventListener('click', async (e) => {
                        const id = (e.target as HTMLElement).getAttribute('data-id');
                        const request = activeRequests.find((r: any) => r.id === id);
                        if (request) {
                            (e.target as HTMLButtonElement).disabled = true;
                            (e.target as HTMLButtonElement).textContent = 'Procesando...';
                            await processDownload(request);
                            updateUI();
                        }
                    });
                });

                document.querySelectorAll('.btn-delete').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const index = parseInt((e.target as HTMLElement).getAttribute('data-index')!);
                        activeRequests.splice(index, 1);
                        localStorage.setItem('satRequests', JSON.stringify(activeRequests));
                        updateUI();
                    });
                });
            } else {
                statusContainer.style.display = 'none';
            }
        }

        updateUI();

        async function fileToBase64(file: File): Promise<string> {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.readAsDataURL(file);
                reader.onload = () => resolve(reader.result as string);
                reader.onerror = error => reject(error);
            });
        }

        async function downloadXmlsAsZip(xmls: any[], packageId: string) {
            const zip = new JSZip();
            xmls.forEach((xml: any) => {
                zip.file(xml.name, xml.content);
            });
            const blob = await zip.generateAsync({ type: 'blob' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `SAT_${packageId}.zip`;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);
        }

        async function processDownload(req: any) {
            try {
                let cerBase64 = '';
                let keyBase64 = '';
                let password = passwordInput.value;

                // 1. Prioridad: ¿Tenemos este RFC guardado en localStorage?
                const specificCreds = savedCredentials[req.rfc];
                
                if (specificCreds) {
                    cerBase64 = specificCreds.cerBase64;
                    keyBase64 = specificCreds.keyBase64;
                    password = specificCreds.password || password;
                } 
                // 2. Si no, ¿hay algo seleccionado actualmente en el dropdown?
                else if (selectedSavedCreds) {
                    cerBase64 = selectedSavedCreds.cerBase64;
                    keyBase64 = selectedSavedCreds.keyBase64;
                    password = selectedSavedCreds.password || password;
                } 
                // 3. Si no, usar los archivos cargados manualmente
                else {
                    const cerFile = cerInput.files?.[0];
                    const keyFile = keyInput.files?.[0];
                    if (cerFile) cerBase64 = await fileToBase64(cerFile);
                    if (keyFile) keyBase64 = await fileToBase64(keyFile);
                }

                if (!cerBase64 || !keyBase64 || !password) {
                    showModal('Faltan Credenciales', 'Para descargar el paquete necesitas tener cargados el archivo .cer, .key y la contraseña.', 'error');
                    return;
                }

                const response = await fetch('/api/sat/descargar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        packageId: req.packageId,
                        cerBase64,
                        keyBase64,
                        password
                    })
                });

                const downloadData = await response.json();
                
                if (downloadData.success) {
                    console.log(`¡Descarga manual lista! ${downloadData.count} XMLs obtenidos.`);
                    await downloadXmlsAsZip(downloadData.xmls, req.packageId);
                    req.status = 'downloaded';
                    req.xmlCount = downloadData.count;
                    localStorage.setItem('satRequests', JSON.stringify(activeRequests));
                    showModal('Descarga Exitosa', `Se han descargado ${downloadData.count} XMLs correctamente.`, 'success');
                } else {
                    console.warn('Fallo descarga manual:', downloadData.message);
                    showModal('Error de Descarga', downloadData.message, 'error');
                }
            } catch (err) {
                console.error('Error en processDownload:', err);
                showModal('Error Crítico', 'Ocurrió un error al intentar la descarga manual.', 'error');
            }
        }

        function base64ToBlob(base64: string, filename: string): File {
            const arr = base64.split(',');
            const mime = arr[0].match(/:(.*?);/)![1];
            const bstr = atob(arr[1]);
            let n = bstr.length;
            const u8arr = new Uint8Array(n);
            while (n--) {
                u8arr[n] = bstr.charCodeAt(n);
            }
            return new File([u8arr], filename, { type: mime });
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const rfc = rfcInput.value.toUpperCase().trim();
            if (!rfc) {
                showModal('RFC Requerido', 'El RFC es obligatorio para guardar o identificar la solicitud.', 'error');
                return;
            }

            submitBtn.disabled = true;
            submitBtn.innerHTML = '<div class="loader"></div> <span>Procesando...</span>';

            const formData = new FormData();
            
            // Usar archivos cargados o archivos guardados
            let cerFile = cerInput.files?.[0];
            let keyFile = keyInput.files?.[0];

            if (!cerFile && selectedSavedCreds) {
                cerFile = base64ToBlob(selectedSavedCreds.cerBase64, selectedSavedCreds.cerName);
            }
            if (!keyFile && selectedSavedCreds) {
                keyFile = base64ToBlob(selectedSavedCreds.keyBase64, selectedSavedCreds.keyName);
            }

            if (!cerFile || !keyFile) {
                showModal('Archivos Faltantes', 'Debes subir los archivos .cer y .key o seleccionar un RFC guardado.', 'error');
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<span>Iniciar Solicitud de Descarga</span>';
                return;
            }

            formData.append('cer', cerFile);
            formData.append('key', keyFile);
            formData.append('password', passwordInput.value);
            formData.append('dateStart', dateStartInput.value);
            formData.append('dateEnd', dateEndInput.value);
            formData.append('type', typeInput.value);
            formData.append('rfc', rfc);

            try {
                // Paso 1: Llamar a nuestra API local
                const response = await fetch('/api/sat/solicitar', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    const finalRfc = result.rfc || rfc; // Usar el RFC devuelto por el servidor si el manual está vacío

                    // Si el usuario pidió guardar credenciales, lo hacemos ahora que sabemos el RFC real
                    if (saveCredsCheckbox.checked) {
                        const cerB64 = await fileToBase64(cerFile);
                        const keyB64 = await fileToBase64(keyFile);
                        savedCredentials[finalRfc] = {
                            cerBase64: cerB64,
                            keyBase64: keyB64,
                            password: passwordInput.value,
                            cerName: cerFile.name,
                            keyName: keyFile.name
                        };
                        localStorage.setItem('satCredentials', JSON.stringify(savedCredentials));
                        updateSavedRfcDropdown();
                        console.log('Credenciales guardadas localmente para ' + finalRfc);
                    }

                    const newRequest = {
                        id: result.requestId,
                        dateStart: dateStartInput.value,
                        dateEnd: dateEndInput.value,
                        type: typeInput.value,
                        rfc: finalRfc,
                        status: 'pending',
                        timestamp: Date.now()
                    };
                    activeRequests.push(newRequest);
                    localStorage.setItem('satRequests', JSON.stringify(activeRequests));
                    updateUI();
                    form.reset();
                    selectedSavedCreds = null;
                    cerInput.required = true;
                    keyInput.required = true;
                    const cerInfo = document.getElementById('cerInfo');
                    const keyInfo = document.getElementById('keyInfo');
                    if (cerInfo) cerInfo.textContent = '';
                    if (keyInfo) keyInfo.textContent = '';
                    savedRfcSelect.value = "";

                    // Restaurar fechas después del reset
                    if (dateStartInput) (dateStartInput as HTMLInputElement).value = localStorage.getItem('satDateStart') || '';
                    if (dateEndInput) (dateEndInput as HTMLInputElement).value = localStorage.getItem('satDateEnd') || '';
                    showModal('Solicitud Enviada', 'La solicitud se envió con éxito al SAT. Revisaremos el estatus automáticamente cada minuto.', 'success');
                } else {
                    showModal('Error del SAT', result.message, 'error');
                }
            } catch (err) {
                console.error(err);
                showModal('Error de Conexión', 'Ocurrió un error al conectar con el servidor local.', 'error');
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<span>Iniciar Solicitud de Descarga</span>';
            }
        });

        // Polling cada minuto
        setInterval(async () => {
            if (activeRequests.length === 0) return;

            console.log('Revisando estatus de solicitudes...');
            for (let i = 0; i < activeRequests.length; i++) {
                const req = activeRequests[i];
                try {
                    const creds = savedCredentials[req.rfc];
                    const authBody: any = { 
                        cerBase64: creds?.cerBase64,
                        keyBase64: creds?.keyBase64,
                        password: creds?.password
                    };

                    // 1. Si está pendiente (o listo pero sin packageId), verificar estatus para obtenerlo
                    if (req.status === 'pending' || (req.status === 'ready' && !req.packageId)) {
                        const res = await fetch(`/api/sat/verificar`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ id: req.id, ...authBody })
                        });
                        const check = await res.json();

                        if (check.status === 'ready') {
                            req.status = 'ready';
                            req.packageId = check.packageId;
                            localStorage.setItem('satRequests', JSON.stringify(activeRequests));
                            updateUI();
                        }
                    }


                    // 2. Si está listo (o recién pasó a listo), intentar descarga automática
                    if (req.status === 'ready' && req.packageId) {
                        console.log('Iniciando descarga automática para:', req.packageId);
                        const downloadRes = await fetch(`/api/sat/descargar`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ packageId: req.packageId, ...authBody })
                        });
                        const downloadData = await downloadRes.json();
                        
                        if (downloadData.success) {
                            console.log(`¡Descarga automática lista! ${downloadData.count} XMLs obtenidos del paquete ${req.packageId}.`);
                            await downloadXmlsAsZip(downloadData.xmls, req.packageId);
                            req.status = 'downloaded';
                            req.xmlCount = downloadData.count;
                            localStorage.setItem('satRequests', JSON.stringify(activeRequests));
                            updateUI();
                        } else {
                            console.warn('Fallo descarga automática:', downloadData.message);
                        }
                    }
                } catch (e) {
                    console.error('Error en polling:', e);
                }
            }
        }, 30000);

    </script>
</body>
</html>
