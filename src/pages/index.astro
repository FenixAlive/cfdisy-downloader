---
// src/pages/index.astro
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>CFDIsy | SAT Downloader</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #6366f1;
            --primary-hover: #4f46e5;
            --bg: #0f172a;
            --card-bg: rgba(30, 41, 59, 0.7);
            --text: #f8fafc;
            --text-dim: #94a3b8;
            --border: rgba(255, 255, 255, 0.1);
            --accent: #f43f5e;
            --success: #10b981;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg);
            background-image: 
                radial-gradient(at 0% 0%, rgba(99, 102, 241, 0.15) 0, transparent 50%), 
                radial-gradient(at 100% 100%, rgba(244, 63, 94, 0.1) 0, transparent 50%);
            color: var(--text);
            margin: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .container {
            width: 90%;
            max-width: 800px;
            margin: 2rem auto;
            padding: 2rem;
        }

        header {
            text-align: center;
            margin-bottom: 3rem;
        }

        h1 {
            font-size: 3rem;
            margin: 0;
            background: linear-gradient(to right, #818cf8, #f472b6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 700;
        }

        p.subtitle {
            color: var(--text-dim);
            font-size: 1.1rem;
        }

        .card {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--border);
            border-radius: 1.5rem;
            padding: 2rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .full-width {
            grid-column: 1 / -1;
        }

        label {
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--text-dim);
        }

        input, select {
            background: rgba(15, 23, 42, 0.5);
            border: 1px solid var(--border);
            border-radius: 0.75rem;
            padding: 0.75rem 1rem;
            color: white;
            font-family: inherit;
            transition: all 0.2s;
        }

        input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
        }

        .btn {
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 0.75rem;
            padding: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            margin-top: 1rem;
        }

        .btn:hover {
            background: var(--primary-hover);
            transform: translateY(-1px);
        }

        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .status-container {
            margin-top: 2rem;
            display: none;
        }

        .download-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .download-item {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: 1rem;
            padding: 1rem;
            margin-bottom: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .item-info h3 {
            margin: 0;
            font-size: 1rem;
        }

        .item-info p {
            margin: 0;
            font-size: 0.8rem;
            color: var(--text-dim);
        }

        .badge {
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .badge.pending { background: rgba(234, 179, 8, 0.2); color: #fbbf24; }
        .badge.ready { background: rgba(16, 185, 129, 0.2); color: #34d399; }
        .badge.error { background: rgba(244, 63, 94, 0.2); color: #fb7185; }

        .loader {
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>CFDIsy Downloader</h1>
            <p class="subtitle">Descarga masiva de facturas desde el Web Service del SAT de forma segura.</p>
        </header>

        <div class="card">
            <form id="downloadForm">
                <div class="form-grid">
                    <div class="form-group full-width" style="display: none;">
                        <label for="savedRfc">RFCs Guardados</label>
                        <select id="savedRfc">
                            <option value="">-- Seleccionar RFC Guardado --</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="cerFile">Certificado (.cer)</label>
                        <input type="file" id="cerFile" accept=".cer" required />
                        <span id="cerInfo" style="font-size: 0.8rem; color: #666; margin-top: 2px; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"></span>
                    </div>
                    <div class="form-group">
                        <label for="keyFile">Llave Privada (.key)</label>
                        <input type="file" id="keyFile" accept=".key" required />
                        <span id="keyInfo" style="font-size: 0.8rem; color: #666; margin-top: 2px; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"></span>
                    </div>
                    <div class="form-group full-width">
                        <label for="password">Contraseña e.firma</label>
                        <input type="password" id="password" placeholder="Tu contraseña" required />
                    </div>
                    <div class="form-group">
                        <label for="dateStart">Fecha Inicial</label>
                        <input type="date" id="dateStart" required />
                    </div>
                    <div class="form-group">
                        <label for="dateEnd">Fecha Final</label>
                        <input type="date" id="dateEnd" required />
                    </div>
                    <div class="form-group">
                        <label for="type">Tipo de CFDI</label>
                        <select id="type">
                            <option value="emitidas">Emitidas</option>
                            <option value="recibidas">Recibidas</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="rfc">RFC (Opcional si viene en el .cer)</label>
                        <input type="text" id="rfc" placeholder="ABCD123456..."/>
                    </div>
                    
                    <div class="form-group full-width" style="flex-direction: row; align-items: center; gap: 0.5rem; margin-top: 0.5rem;">
                        <input type="checkbox" id="saveCreds" style="width: auto;" />
                        <label for="saveCreds" style="margin: 0; cursor: pointer;">Guardar credenciales en este navegador</label>
                    </div>
                    
                    <button type="submit" class="btn full-width" id="submitBtn">
                        <span>Iniciar Solicitud de Descarga</span>
                    </button>
                </div>
            </form>
        </div>

        <div class="status-container" id="statusContainer">
            <h2>Solicitudes en Curso</h2>
            <ul class="download-list" id="downloadList">
                <!-- Solicitudes se añadirán aquí -->
            </ul>
        </div>
    </div>

    <script>
        const form = document.getElementById('downloadForm') as HTMLFormElement;
        const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
        const statusContainer = document.getElementById('statusContainer') as HTMLElement;
        const downloadList = document.getElementById('downloadList') as HTMLElement;
        const dateStartInput = document.getElementById('dateStart') as HTMLInputElement;
        const dateEndInput = document.getElementById('dateEnd') as HTMLInputElement;
        const cerInput = document.getElementById('cerFile') as HTMLInputElement;
        const keyInput = document.getElementById('keyFile') as HTMLInputElement;
        const passwordInput = document.getElementById('password') as HTMLInputElement;
        const rfcInput = document.getElementById('rfc') as HTMLInputElement;
        const typeInput = document.getElementById('type') as HTMLSelectElement;
        const saveCredsCheckbox = document.getElementById('saveCreds') as HTMLInputElement;
        const savedRfcSelect = document.getElementById('savedRfc') as HTMLSelectElement;

        // Estructura de credenciales guardadas: { [rfc]: { cerBase64, keyBase64, password, cerName, keyName } }
        let savedCredentials = JSON.parse(localStorage.getItem('satCredentials') || '{}');
        let selectedSavedCreds: any = null;

        function updateSavedRfcDropdown() {
            const rfcs = Object.keys(savedCredentials);
            if (rfcs.length > 0) {
                savedRfcSelect.parentElement!.style.display = 'flex';
                savedRfcSelect.innerHTML = '<option value="">-- Seleccionar RFC Guardado --</option>' + 
                    rfcs.map(rfc => `<option value="${rfc}">${rfc}</option>`).join('');
            } else {
                savedRfcSelect.parentElement!.style.display = 'none';
            }
        }

        updateSavedRfcDropdown();

        savedRfcSelect.addEventListener('change', () => {
            const rfc = savedRfcSelect.value;
            const cerInfo = document.getElementById('cerInfo');
            const keyInfo = document.getElementById('keyInfo');
            
            if (rfc) {
                const creds = savedCredentials[rfc];
                if (!creds || !creds.cerBase64 || !creds.keyBase64) {
                    alert(`Error: Faltan archivos .cer o .key para el RFC ${rfc}. Por favor, vuelve a cargarlos.`);
                    savedRfcSelect.value = "";
                    selectedSavedCreds = null;
                    cerInput.required = true;
                    keyInput.required = true;
                    if (cerInfo) cerInfo.textContent = '';
                    if (keyInfo) keyInfo.textContent = '';
                    return;
                }
                
                rfcInput.value = rfc;
                passwordInput.value = creds.password;
                selectedSavedCreds = creds;
                
                // Quitar requerimiento de archivos ya que usamos los guardados
                cerInput.required = false;
                keyInput.required = false;
                
                // Mostrar feedback visual
                if (cerInfo) cerInfo.textContent = `📁 Guardado: ${creds.cerName}`;
                if (keyInfo) keyInfo.textContent = `📁 Guardado: ${creds.keyName}`;
                
                console.log(`Cargadas credenciales para ${rfc}. (Archivos: ${creds.cerName}, ${creds.keyName})`);
            } else {
                selectedSavedCreds = null;
                cerInput.required = true;
                keyInput.required = true;
                if (cerInfo) cerInfo.textContent = '';
                if (keyInfo) keyInfo.textContent = '';
            }
        });

        // Cargar solicitudes previas de localStorage
        let activeRequests = JSON.parse(localStorage.getItem('satRequests') || '[]');
        
        // Cargar fechas previas
        const savedStart = localStorage.getItem('satDateStart');
        const savedEnd = localStorage.getItem('satDateEnd');
        if (savedStart && dateStartInput) (dateStartInput as HTMLInputElement).value = savedStart;
        if (savedEnd && dateEndInput) (dateEndInput as HTMLInputElement).value = savedEnd;

        // Guardar fechas al cambiar
        dateStartInput.addEventListener('change', () => localStorage.setItem('satDateStart', (dateStartInput as HTMLInputElement).value));
        dateEndInput.addEventListener('change', () => localStorage.setItem('satDateEnd', (dateEndInput as HTMLInputElement).value));

        function updateUI() {
            if (!statusContainer || !downloadList) return;
            if (activeRequests.length > 0) {
                statusContainer.style.display = 'block';
                downloadList.innerHTML = activeRequests.map((req: any) => `
                    <li class="download-item">
                        <div class="item-info">
                            <h3>Solicitud: ${req.id}</h3>
                            <p>${req.dateStart} al ${req.dateEnd} | ${req.type}</p>
                        </div>
                        <div class="item-status">
                            <span class="badge ${req.status}">${req.status === 'pending' ? 'Buscando en SAT...' : 'Listo'}</span>
                        </div>
                    </li>
                `).join('');
            } else {
                statusContainer.style.display = 'none';
            }
        }

        updateUI();

        async function fileToBase64(file: File): Promise<string> {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.readAsDataURL(file);
                reader.onload = () => resolve(reader.result as string);
                reader.onerror = error => reject(error);
            });
        }

        function base64ToBlob(base64: string, filename: string): File {
            const arr = base64.split(',');
            const mime = arr[0].match(/:(.*?);/)![1];
            const bstr = atob(arr[1]);
            let n = bstr.length;
            const u8arr = new Uint8Array(n);
            while (n--) {
                u8arr[n] = bstr.charCodeAt(n);
            }
            return new File([u8arr], filename, { type: mime });
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const rfc = rfcInput.value.toUpperCase().trim();
            if (!rfc) {
                alert('El RFC es obligatorio para guardar o identificar la solicitud.');
                return;
            }

            submitBtn.disabled = true;
            submitBtn.innerHTML = '<div class="loader"></div> <span>Procesando...</span>';

            const formData = new FormData();
            
            // Usar archivos cargados o archivos guardados
            let cerFile = cerInput.files?.[0];
            let keyFile = keyInput.files?.[0];

            if (!cerFile && selectedSavedCreds) {
                cerFile = base64ToBlob(selectedSavedCreds.cerBase64, selectedSavedCreds.cerName);
            }
            if (!keyFile && selectedSavedCreds) {
                keyFile = base64ToBlob(selectedSavedCreds.keyBase64, selectedSavedCreds.keyName);
            }

            if (!cerFile || !keyFile) {
                alert('Debes subir los archivos .cer y .key o seleccionar un RFC guardado.');
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<span>Iniciar Solicitud de Descarga</span>';
                return;
            }

            formData.append('cer', cerFile);
            formData.append('key', keyFile);
            formData.append('password', passwordInput.value);
            formData.append('dateStart', dateStartInput.value);
            formData.append('dateEnd', dateEndInput.value);
            formData.append('type', typeInput.value);
            formData.append('rfc', rfc);

            try {
                // Si el usuario pidió guardar credenciales, lo hacemos antes o independientemente del resultado del SAT
                if (saveCredsCheckbox.checked) {
                    const cerB64 = await fileToBase64(cerFile);
                    const keyB64 = await fileToBase64(keyFile);
                    savedCredentials[rfc] = {
                        cerBase64: cerB64,
                        keyBase64: keyB64,
                        password: passwordInput.value,
                        cerName: cerFile.name,
                        keyName: keyFile.name
                    };
                    localStorage.setItem('satCredentials', JSON.stringify(savedCredentials));
                    updateSavedRfcDropdown();
                    console.log('Credenciales guardadas localmente para ' + rfc);
                }

                // Paso 1: Llamar a nuestra API local
                const response = await fetch('/api/sat/solicitar', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    const newRequest = {
                        id: result.requestId,
                        dateStart: dateStartInput.value,
                        dateEnd: dateEndInput.value,
                        type: typeInput.value,
                        rfc: rfc,
                        status: 'pending',
                        timestamp: Date.now()
                    };
                    activeRequests.push(newRequest);
                    localStorage.setItem('satRequests', JSON.stringify(activeRequests));
                    updateUI();
                    form.reset();
                    selectedSavedCreds = null;
                    cerInput.required = true;
                    keyInput.required = true;
                    const cerInfo = document.getElementById('cerInfo');
                    const keyInfo = document.getElementById('keyInfo');
                    if (cerInfo) cerInfo.textContent = '';
                    if (keyInfo) keyInfo.textContent = '';
                    savedRfcSelect.value = "";

                    // Restaurar fechas después del reset
                    if (dateStartInput) (dateStartInput as HTMLInputElement).value = localStorage.getItem('satDateStart') || '';
                    if (dateEndInput) (dateEndInput as HTMLInputElement).value = localStorage.getItem('satDateEnd') || '';
                    alert('Solicitud enviada con éxito al SAT. Revisaremos el estatus cada minuto.');
                } else {
                    alert('Error: ' + result.message);
                }
            } catch (err) {
                console.error(err);
                alert('Ocurrió un error al conectar con el servidor local.');
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<span>Iniciar Solicitud de Descarga</span>';
            }
        });

        // Polling cada minuto
        setInterval(async () => {
            if (activeRequests.length === 0) return;

            console.log('Revisando estatus de solicitudes...');
            for (let i = 0; i < activeRequests.length; i++) {
                const req = activeRequests[i];
                try {
                    const creds = savedCredentials[req.rfc];
                    const authBody: any = { 
                        cerBase64: creds?.cerBase64,
                        keyBase64: creds?.keyBase64,
                        password: creds?.password
                    };

                    // 1. Si está pendiente (o listo pero sin packageId), verificar estatus para obtenerlo
                    if (req.status === 'pending' || (req.status === 'ready' && !req.packageId)) {
                        const res = await fetch(`/api/sat/verificar`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ id: req.id, ...authBody })
                        });
                        const check = await res.json();

                        if (check.status === 'ready') {
                            req.status = 'ready';
                            req.packageId = check.packageId;
                            localStorage.setItem('satRequests', JSON.stringify(activeRequests));
                            updateUI();
                        }
                    }


                    // 2. Si está listo (o recién pasó a listo), intentar descarga automática
                    if (req.status === 'ready' && req.packageId) {
                        console.log('Iniciando descarga automática para:', req.packageId);
                        const downloadRes = await fetch(`/api/sat/descargar`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ packageId: req.packageId, ...authBody })
                        });
                        const downloadData = await downloadRes.json();
                        
                        if (downloadData.success) {
                            console.log(`¡Descarga lista! ${downloadData.count} XMLs obtenidos.`);
                            // Marcamos como descargado para que no reintente en el siguiente ciclo
                            req.status = 'downloaded';
                            req.xmlCount = downloadData.count;
                            localStorage.setItem('satRequests', JSON.stringify(activeRequests));
                            updateUI();
                            alert(`¡Descarga automática lista! Se han obtenido ${downloadData.count} XMLs del paquete ${req.packageId}.`);
                        } else {
                            console.warn('Fallo descarga automática:', downloadData.message);
                        }
                    }
                } catch (e) {
                    console.error('Error en polling:', e);
                }
            }
        }, 60000);

    </script>
</body>
</html>
