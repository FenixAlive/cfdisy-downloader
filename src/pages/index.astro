        updateSavedRfcDropdown();

        savedRfcSelect.addEventListener('change', () => {
            const rfc = savedRfcSelect.value;
            const cerInfo = document.getElementById('cerInfo');
            const keyInfo = document.getElementById('keyInfo');
            
            if (rfc) {
                const creds = savedCredentials[rfc];
                if (!creds || !creds.cerBase64 || !creds.keyBase64) {
                    showModal('Credenciales Incompletas', `Faltan archivos .cer o .key para el RFC ${rfc}. Por favor, vuelve a cargarlos.`, 'error');
                    savedRfcSelect.value = "";
