        });

        // Cargar solicitudes previas de localStorage
        let activeRequests = JSON.parse(localStorage.getItem('satRequests') || '[]');
        
        // Cargar fechas previas
        const savedStart = localStorage.getItem('satDateStart');
        const savedEnd = localStorage.getItem('satDateEnd');
        if (savedStart && dateStartInput) dateStartInput.value = savedStart;
        if (savedEnd && dateEndInput) dateEndInput.value = savedEnd;

        // Guardar fechas al cambiar
        dateStartInput.addEventListener('change', () => localStorage.setItem('satDateStart', dateStartInput.value));
        dateEndInput.addEventListener('change', () => localStorage.setItem('satDateEnd', dateEndInput.value));

        let nextCheckTime = Date.now() + 120000;

        function updateUI() {
            if (!statusContainer || !downloadList) return;
            if (activeRequests.length > 0) {
                statusContainer.style.display = 'block';
                downloadList.innerHTML = activeRequests.map((req, index) => {
                    let statusLabel = 'Pendiente';
                    if (req.status === 'pending') {
                        const diff = Math.max(0, Math.ceil((nextCheckTime - Date.now()) / 1000));
                        statusLabel = `Pendiente (Revisando en ${diff}s)`;
                    }
                    if (req.status === 'ready') statusLabel = '¡Listo para descargar!';
                    if (req.status === 'downloaded') statusLabel = `Descargado (${req.xmlCount} XMLs)`;
                    if (req.status === 'error') statusLabel = 'Error';

                    return `
                        <tr class="download-row">
                            <td style="vertical-align: middle;"><strong>${req.rfc || 'N/A'}</strong></td>
                            <td style="vertical-align: middle; font-size:0.85rem; opacity:0.8;">${req.id}</td>
                            <td style="vertical-align: middle; font-size:0.85rem;">${req.dateStart} al ${req.dateEnd}</td>
                            <td style="vertical-align: middle;">${req.type}</td>
                            <td style="vertical-align: middle;"><span class="text-${req.status}" style="font-weight:600;">${statusLabel}</span></td>
                            <td style="vertical-align: middle;">
                                <div style="display:flex; gap:0.4rem; align-items:center; justify-content:flex-end;">
                                    ${req.status === 'ready' || req.status === 'downloaded' ? `
                                        <button class="btn-download" data-id="${req.id}" style="background: ${req.status === 'downloaded' ? 'var(--primary)' : 'var(--success)'}; color: white; border: none; padding: 0.4rem 0.7rem; border-radius: 0.4rem; cursor: pointer; font-weight: 600; font-size: 0.8rem;">
                                            ${req.status === 'downloaded' ? 'Re-descargar ZIP' : 'Descargar ZIP'}
                                        </button>
                                    ` : ''}
                                    ${req.status === 'downloaded' || req.status === 'error' ? `
                                        <button class="btn-delete" data-index="${index}" style="background: rgba(244, 63, 94, 0.06); color: var(--accent); border: 1px solid rgba(244,63,94,0.2); padding: 0.35rem 0.6rem; border-radius: 0.4rem; cursor: pointer; font-size: 0.75rem;">
                                            Eliminar
                                        </button>
                                    ` : ''}
                                    ${req.status === 'pending' ? `
                                        <button class="btn-verify-now" data-id="${req.id}" style="background: rgba(99,102,241,0.08); color: var(--primary); border: 1px solid rgba(99,102,241,0.12); padding: 0.35rem 0.6rem; border-radius: 0.4rem; cursor: pointer; font-size: 0.75rem; font-weight:600;">
                                            Verificar Ahora
                                        </button>
                                        <button class="btn-delete-pending" data-index="${index}" style="background: rgba(244, 63, 94, 0.06); color: var(--accent); border: 1px solid rgba(244,63,94,0.2); padding: 0.35rem 0.6rem; border-radius: 0.4rem; cursor: pointer; font-size: 0.75rem;">
                                            Eliminar
                                        </button>
                                        <div class="loader" style="margin-left:0.25rem;"></div>
                                    ` : ''}
                                </div>
                            </td>
                        </tr>
                    `;
                }).join('');

                // Agregar listeners a los nuevos botones
                document.querySelectorAll('.btn-download').forEach(btn => {
                    btn.addEventListener('click', async (e) => {
                        const id = e.target.getAttribute('data-id');
                        const request = activeRequests.find(r => r.id === id);
                        if (request) {
                            e.target.disabled = true;
                            e.target.textContent = 'Procesando...';
                            await processDownload(request);
                            updateUI();
                        }
                    });
                });

                document.querySelectorAll('.btn-delete').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const index = parseInt(e.target.getAttribute('data-index'));
                        activeRequests.splice(index, 1);
                        localStorage.setItem('satRequests', JSON.stringify(activeRequests));
                        updateUI();
                    });
                });

                document.querySelectorAll('.btn-verify-now').forEach(btn => {
                    btn.addEventListener('click', async (e) => {
                        const id = e.target.getAttribute('data-id');
                        const button = e.target;
                        const request = activeRequests.find(r => r.id === id);
                        if (!request) return;

                        try {
                            button.disabled = true;
                            const origText = button.textContent;
                            button.textContent = 'Verificando...';

                            let creds = savedCredentials[request.rfc];
                            if (!creds || !creds.cerBase64 || !creds.keyBase64 || !creds.password) {
                                const provided = await askForCredentials(request.rfc);
                                if (provided) {
                                    creds = { cerBase64: provided.cerBase64, keyBase64: provided.keyBase64, password: provided.password };
                                } else {
                                    button.textContent = origText;
                                    button.disabled = false;
                                    return;
                                }
                            }

                            const body = { id: request.id, cerBase64: creds?.cerBase64, keyBase64: creds?.keyBase64, password: creds?.password };

                            const res = await fetch(`/api/sat/verificar`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(body)
                            });
                            const check = await res.json();

                            if (check.status === 'ready') {
                                request.status = 'ready';
                                request.packageId = check.packageId;
                                localStorage.setItem('satRequests', JSON.stringify(activeRequests));
                                updateUI();
                                await processDownload(request);
                                updateUI();
                            } else {
                                maybeNotify('Aún Pendiente', 'La solicitud todavía se encuentra en proceso en el SAT. Reintenta más tarde.', 'info');
                                button.textContent = origText;
                                button.disabled = false;
                            }
                        } catch (err) {
                            console.error('Error al verificar manualmente:', err);
                            showModal('Error', 'Ocurrió un error al verificar la solicitud.', 'error');
                            button.disabled = false;
                        }
                    });
                });

                document.querySelectorAll('.btn-delete-pending').forEach(btn => {
                    btn.addEventListener('click', async (e) => {
                        const index = parseInt(e.target.getAttribute('data-index'));
                        if (!Number.isNaN(index)) {
                            const confirmed = await showConfirm('Confirmar eliminación', '¿Eliminar esta solicitud pendiente?');
                            if (confirmed) {
                                activeRequests.splice(index, 1);
                                localStorage.setItem('satRequests', JSON.stringify(activeRequests));
                                updateUI();
                            }
                        }
                    });
                });
            } else {
                statusContainer.style.display = 'none';
            }
        }

        updateUI();

