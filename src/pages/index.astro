        function saveDownloadedXmls(xmls, rfc) {
            xmls.forEach((xmlFile) => {
                try {
                    const parsed = parser.parse(xmlFile.content);
                    const comp = parsed.Comprobante;
                    if (!comp) return;

                    const tfd = comp.Complemento?.TimbreFiscalDigital;
                    
                    const historyItem = {
                        fecha: comp.Fecha,
                        uuid: tfd?.UUID,
                        emisorRfc: comp.Emisor?.Rfc,
                        emisorNombre: comp.Emisor?.Nombre,
                        receptorRfc: comp.Receptor?.Rfc,
                        receptorNombre: comp.Receptor?.Nombre,
                        total: comp.Total,
                        subtotal: comp.SubTotal,
                        moneda: comp.Moneda,
                        version: comp.Version,
                        tipo: comp.TipoDeComprobante,
                        esEmisor: comp.Emisor?.Rfc?.toUpperCase() === rfc?.toUpperCase()
                    };

                    if (historyItem.uuid && !savedXmls.some(x => x.uuid === historyItem.uuid)) {
                        savedXmls.push(historyItem);
                    }
                } catch (e) {
                    console.error('Error al parsear XML:', e);
                }
            });
            localStorage.setItem('satXmlHistory', JSON.stringify(savedXmls));
            updateHistoryUI();
        }

        function exportToExcel(tipo) {
            const worksheetData = savedXmls
                .filter(xml => {
                    const isEmitida = xml.esEmisor === true;
                    return tipo === 'emitidas' ? isEmitida : !isEmitida;
                })
                .map(xml => ({
                    'Fecha': xml.fecha,
                    'UUID': xml.uuid,
                    'RFC Emisor': xml.emisorRfc,
                    'Nombre Emisor': xml.emisorNombre,
                    'RFC Receptor': xml.receptorRfc,
                    'Nombre Receptor': xml.receptorNombre,
                    'Subtotal': Number(xml.subtotal || 0),
                    'Total': Number(xml.total || 0),
                    'Moneda': xml.moneda,
                    'Tipo': xml.tipo,
                    'Versión': xml.version
                }));

            if (worksheetData.length === 0) {
                maybeNotify('Sin Datos', `No hay facturas ${tipo} para exportar.`, 'info');
                return;
            }

            const ws = XLSX.utils.json_to_sheet(worksheetData);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, "Facturas");
            XLSX.writeFile(wb, `Facturas_${tipo}_${new Date().toISOString().split('T')[0]}.xlsx`);
        }

        exportExcelEmitidos.addEventListener('click', () => exportToExcel('emitidas'));
        exportExcelRecibidos.addEventListener('click', () => exportToExcel('recibidas'));

        async function fileToBase64(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.readAsDataURL(file);
                reader.onload = () => resolve(reader.result);
                reader.onerror = error => reject(error);
            });
        }

        const credsModalOverlay = document.getElementById('credsModalOverlay');
        const credsModalConfirm = document.getElementById('credsModalConfirm');
        const credsModalCancel = document.getElementById('credsModalCancel');

        function askForCredentials(defaultRfc) {
            return new Promise(async (resolve) => {
                try {
                    const modalRfc = document.getElementById('modal-rfc');
                    if (modalRfc && defaultRfc) modalRfc.value = defaultRfc;

                    credsModalOverlay.style.display = 'flex';

                    const cleanup = () => {
                        credsModalOverlay.style.display = 'none';
                        if (credsModalConfirm) credsModalConfirm.onclick = null;
                        if (credsModalCancel) credsModalCancel.onclick = null;
                    };

                    if (credsModalCancel) credsModalCancel.onclick = () => { cleanup(); resolve(null); };

                    if (credsModalConfirm) credsModalConfirm.onclick = async () => {
                        const cerFileEl = document.getElementById('modal-cerFile');
                        const keyFileEl = document.getElementById('modal-keyFile');
                        const passEl = document.getElementById('modal-password');
                        const rfcEl = document.getElementById('modal-rfc');
                        const saveEl = document.getElementById('modal-saveCreds');

                        const cerFile = cerFileEl?.files?.[0];
                        const keyFile = keyFileEl?.files?.[0];
                        const password = passEl?.value || '';
                        const rfcVal = (rfcEl?.value || defaultRfc || '').toUpperCase().trim();

                        if (!cerFile || !keyFile || !password) {
                            showModal('Faltan Credenciales', 'Debes cargar .cer, .key y la contraseña en el modal.', 'error');
                            return;
                        }

                        const cerBase64 = await fileToBase64(cerFile);
                        const keyBase64 = await fileToBase64(keyFile);

                        if (saveEl && saveEl.checked && rfcVal) {
                            savedCredentials[rfcVal] = {
                                cerBase64,
                                keyBase64,
                                password,
                                cerName: cerFile.name,
                                keyName: keyFile.name
                            };
                            localStorage.setItem('satCredentials', JSON.stringify(savedCredentials));
                            updateSavedRfcDropdown();
                        }

                        cleanup();
                        resolve({ cerBase64, keyBase64, password, rfc: rfcVal });
                    };
                } catch (e) {
                    console.error('askForCredentials error', e);
                    resolve(null);
                }
            });
        }

        async function downloadXmlsAsZip(xmls, packageId) {
            const zip = new JSZip();
            xmls.forEach((xml) => {
                zip.file(xml.name, xml.content);
            });
            const blob = await zip.generateAsync({ type: 'blob' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `SAT_${packageId}.zip`;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);
        }

        async function processDownload(req) {
            try {
                let cerBase64 = '';
                let keyBase64 = '';
                let password = passwordInput.value;

                const specificCreds = savedCredentials[req.rfc];
                
                if (specificCreds) {
                    cerBase64 = specificCreds.cerBase64;
                    keyBase64 = specificCreds.keyBase64;
                    password = specificCreds.password || password;
                } else if (selectedSavedCreds) {
                    cerBase64 = selectedSavedCreds.cerBase64;
                    keyBase64 = selectedSavedCreds.keyBase64;
                    password = selectedSavedCreds.password || password;
                } else {
                    const cerFile = cerInput.files?.[0];
                    const keyFile = keyInput.files?.[0];
                    if (cerFile) cerBase64 = await fileToBase64(cerFile);
                    if (keyFile) keyBase64 = await fileToBase64(keyFile);
                }

                if (!cerBase64 || !keyBase64 || !password) {
                    const provided = await askForCredentials(req.rfc);
                    if (!provided) {
                        showModal('Faltan Credenciales', 'No se proporcionaron credenciales. Operación cancelada.', 'error');
                        return;
                    }
                    cerBase64 = provided.cerBase64;
                    keyBase64 = provided.keyBase64;
                    password = provided.password;
                }

                const response = await fetch('/api/sat/descargar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        packageId: req.packageId,
                        cerBase64,
                        keyBase64,
                        password
                    })
                });

                const downloadData = await response.json();
                
                if (downloadData.success) {
                    console.log(`¡Descarga manual lista! ${downloadData.count} XMLs obtenidos.`);
                    await downloadXmlsAsZip(downloadData.xmls, req.packageId);
                    req.status = 'downloaded';
                    req.xmlCount = downloadData.count;
                    localStorage.setItem('satRequests', JSON.stringify(activeRequests));
                    saveDownloadedXmls(downloadData.xmls, req.rfc);
                    showModal('Descarga Exitosa', `Se han descargado y guardado ${downloadData.count} XMLs correctamente.`, 'success');
                } else {
                    console.warn('Fallo descarga manual:', downloadData.message);
                    showModal('Error de Descarga', downloadData.message, 'error');
                }
            } catch (err) {
                console.error('Error en processDownload:', err);
                showModal('Error Crítico', 'Ocurrió un error al intentar la descarga manual.', 'error');
            }
        }

        function base64ToBlob(base64, filename) {
            const arr = base64.split(',');
            const mime = arr[0].match(/:(.*?);/)[1];
            const bstr = atob(arr[1]);
            let n = bstr.length;
            const u8arr = new Uint8Array(n);
            while (n--) {
                u8arr[n] = bstr.charCodeAt(n);
            }
            return new File([u8arr], filename, { type: mime });
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const rfc = rfcInput.value.toUpperCase().trim();
            if (!rfc) {
                showModal('RFC Requerido', 'El RFC es obligatorio para guardar o identificar la solicitud.', 'error');
                return;
            }

            submitBtn.disabled = true;
            submitBtn.innerHTML = '<div class="loader"></div> <span>Procesando...</span>';

            const formData = new FormData();
            
            let cerFile = cerInput.files?.[0];
            let keyFile = keyInput.files?.[0];

            if (!cerFile && selectedSavedCreds) {
                cerFile = base64ToBlob(selectedSavedCreds.cerBase64, selectedSavedCreds.cerName);
            }
            if (!keyFile && selectedSavedCreds) {
                keyFile = base64ToBlob(selectedSavedCreds.keyBase64, selectedSavedCreds.keyName);
            }

            if (!cerFile || !keyFile) {
                showModal('Archivos Faltantes', 'Debes subir los archivos .cer y .key o seleccionar un RFC guardado.', 'error');
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<span>Iniciar Solicitud de Descarga</span>';
                return;
            }

            formData.append('cer', cerFile);
            formData.append('key', keyFile);
            formData.append('password', passwordInput.value);
            formData.append('dateStart', dateStartInput.value);
            formData.append('dateEnd', dateEndInput.value);
            formData.append('type', typeInput.value);
            formData.append('rfc', rfc);
            formData.append('saveCreds', saveCredsCheckbox.checked.toString());

            try {
                const response = await fetch('/api/sat/solicitar', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    const finalRfc = result.rfc || rfc;

                    // Guardar credenciales si el servidor las devolvió
                    if (result.saveCredentials && finalRfc) {
                        savedCredentials[finalRfc] = {
                            cerBase64: result.saveCredentials.cerBase64,
                            keyBase64: result.saveCredentials.keyBase64,
                            password: result.saveCredentials.password,
                            cerName: result.saveCredentials.cerName,
                            keyName: result.saveCredentials.keyName
                        };
                        localStorage.setItem('satCredentials', JSON.stringify(savedCredentials));
                        updateSavedRfcDropdown();
                        console.log('Credenciales guardadas localmente para ' + finalRfc);
                    }

                    const newRequest = {
                        id: result.requestId,
                        dateStart: dateStartInput.value,
                        dateEnd: dateEndInput.value,
                        type: typeInput.value,
                        rfc: finalRfc,
                        status: 'pending',
                        timestamp: Date.now()
                    };
                    activeRequests.push(newRequest);
                    localStorage.setItem('satRequests', JSON.stringify(activeRequests));
                    updateUI();
                    form.reset();
                    selectedSavedCreds = null;
                    cerInput.required = true;
                    keyInput.required = true;
                    const cerInfo = document.getElementById('cerInfo');
                    const keyInfo = document.getElementById('keyInfo');
                    if (cerInfo) cerInfo.textContent = '';
                    if (keyInfo) keyInfo.textContent = '';
                    savedRfcSelect.value = "";

                    if (dateStartInput) dateStartInput.value = localStorage.getItem('satDateStart') || '';
                    if (dateEndInput) dateEndInput.value = localStorage.getItem('satDateEnd') || '';
                    showToast('Solicitud Enviada', 'La solicitud se envió con éxito al SAT. Revisaremos el estatus automáticamente cada 2 minutos.', 'success');
                } else {
                    // Guardar credenciales incluso si la solicitud falló
                    if (result.saveCredentials && result.rfc) {
                        savedCredentials[result.rfc] = {
                            cerBase64: result.saveCredentials.cerBase64,
                            keyBase64: result.saveCredentials.keyBase64,
                            password: result.saveCredentials.password,
                            cerName: result.saveCredentials.cerName,
                            keyName: result.saveCredentials.keyName
                        };
                        localStorage.setItem('satCredentials', JSON.stringify(savedCredentials));
                        updateSavedRfcDropdown();
                        console.log('Credenciales guardadas localmente para ' + result.rfc);
                    }
                    showModal('Error del SAT', result.message, 'error');
                }
            } catch (err) {
                console.error(err);
                
                // Intentar extraer credenciales de la respuesta de error
                try {
                    const errorResponse = await err.json?.();
                    if (errorResponse?.saveCredentials && errorResponse?.rfc) {
                        savedCredentials[errorResponse.rfc] = {
                            cerBase64: errorResponse.saveCredentials.cerBase64,
                            keyBase64: errorResponse.saveCredentials.keyBase64,
                            password: errorResponse.saveCredentials.password,
                            cerName: errorResponse.saveCredentials.cerName,
                            keyName: errorResponse.saveCredentials.keyName
                        };
                        localStorage.setItem('satCredentials', JSON.stringify(savedCredentials));
                        updateSavedRfcDropdown();
                        console.log('Credenciales guardadas localmente para ' + errorResponse.rfc);
                    }
                } catch (parseError) {
                    // No se pudo parsear la respuesta de error
                }
                
                showModal('Error de Conexión', 'Ocurrió un error al conectar con el servidor local.', 'error');
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<span>Iniciar Solicitud de Descarga</span>';
            }
        });

        // Polling cada 2 minutos
        setInterval(async () => {
            if (activeRequests.length === 0) return;

            console.log('Revisando estatus de solicitudes...');
            for (let i = 0; i < activeRequests.length; i++) {
                const req = activeRequests[i];
                try {
                    const creds = savedCredentials[req.rfc];
                    const authBody = { 
                        cerBase64: creds?.cerBase64,
                        keyBase64: creds?.keyBase64,
                        password: creds?.password
                    };

                    if (req.status === 'pending' || (req.status === 'ready' && !req.packageId)) {
                        const res = await fetch(`/api/sat/verificar`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ id: req.id, ...authBody })
                        });
                        const check = await res.json();

                        if (check.status === 'ready') {
                            req.status = 'ready';
                            req.packageId = check.packageId;
                            localStorage.setItem('satRequests', JSON.stringify(activeRequests));
                            updateUI();
                        }
                    }

                    if (req.status === 'ready' && req.packageId) {
                        console.log('Iniciando descarga automática para:', req.packageId);
                        const downloadRes = await fetch(`/api/sat/descargar`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ packageId: req.packageId, ...authBody })
                        });
                        const downloadData = await downloadRes.json();
                        
                        if (downloadData.success) {
                            console.log(`¡Descarga automática lista! ${downloadData.count} XMLs obtenidos del paquete ${req.packageId}.`);
                            await downloadXmlsAsZip(downloadData.xmls, req.packageId);
                            req.status = 'downloaded';
                            req.xmlCount = downloadData.count;
                            localStorage.setItem('satRequests', JSON.stringify(activeRequests));
                            saveDownloadedXmls(downloadData.xmls, req.rfc);
                            updateUI();
                        } else {
                            console.warn('Fallo descarga automática:', downloadData.message);
                        }
                    }
                } catch (e) {
                    console.error('Error en polling:', e);
                }
            }
            nextCheckTime = Date.now() + 120000;
            updateUI();
        }, 120000);

        // Actualizar contador visual cada segundo
        setInterval(() => {
            if (activeRequests.some(r => r.status === 'pending')) {
                updateUI();
            }
        }, 1000);
    </script>
</body>
</html>
