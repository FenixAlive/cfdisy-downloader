                if (keyInfo) keyInfo.textContent = `📁 Guardado: ${creds.keyName}`;
                
                console.log(`Cargadas credenciales para ${rfc}. (Archivos: ${creds.cerName}, ${creds.keyName})`);
            } else {
                selectedSavedCreds = null;
                cerInput.required = true;
                keyInput.required = true;
                if (cerInfo) cerInfo.textContent = '';
                if (keyInfo) keyInfo.textContent = '';
